# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Production app URL (must match Supabase Auth → URL Configuration → Site URL)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Voice calling — off by default; set to true to enable
# NEXT_PUBLIC_ENABLE_VOICE_CALLS=true

# Server-only (Edge Function / API routes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=your-cron-secret

# Voice calling — Metered.ca TURN (https://www.metered.ca/). Optional in dev (STUN-only fallback).
METERED_TURN_API_KEY=your-metered-credential-api-key
METERED_TURN_APP_NAME=your-app-name